{
  "name": "@qlever-llc/lf-sync",
  "version": "3.2.1",
  "description": "Trellis LaserFiche sync service",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "start": "node ${INSPECT:-} --enable-source-maps dist/index.js",
    "script:clean-dups": "node dist/scripts/lf/clean-dups.js",
    "script:trash-by-doc-type": "node dist/scripts/lf/trash-by-doc-type.js",
    "script:move-entry": "node dist/scripts/lf/move-entry.js",
    "script:delete-entry": "node dist/scripts/lf/delete-entry.js",
    "script:find-zero-sized": "node dist/scripts/lf/find-zero-sized.js",
    "test": "yarn build test && c8 ava",
    "test:debug": "ava -T 60m -svc 1 --no-worker-threads",
    "test:live": "cross-env NOCK_MODE=live yarn test",
    "test:record": "cross-env NOCK_MODE=record yarn test",
    "lint": "biome"
  },
  "ava": {
    "failFast": false,
    "concurrency": 1,
    "files": [
      "**/*.test.ts"
    ],
    "typescript": {
      "extensions": [
        "ts"
      ],
      "rewritePaths": {
        "src/": "dist/",
        "test/": ".test/"
      },
      "compile": false
    }
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true,
    "src": "src",
    "exclude": [
      ".pnp.*",
      ".test"
    ]
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@oada/client": "^6.0.1",
    "@oada/jobs": "^4.7.5",
    "@oada/lib-config": "^4.0.0",
    "@oada/lib-prom": "^4.0.2",
    "@oada/list-lib": "^6.1.0",
    "@oada/pino-debug": "^4.0.1",
    "@oada/types": "^4.1.1",
    "bs58": "^6.0.0",
    "convict": "^6.2.5",
    "cron": "^4.4.0",
    "csv-parse": "^6.2.1",
    "csv-parser": "^3.2.1",
    "csv-stringify": "^6.7.0",
    "csv-writer": "^1.6.0",
    "csvjson": "^5.1.0",
    "debug": "^4.4.3",
    "deep-equal": "^2.2.3",
    "dotenv": "^17.4.2",
    "es-main": "^1.4.0",
    "exponential-backoff": "^3.1.3",
    "formdata-node": "^6.0.3",
    "got": "^15.0.5",
    "json-ptr": "^3.1.1",
    "jsonpath": "^1.3.0",
    "ksuid": "^3.0.0",
    "mime-types": "^3.0.2",
    "mssql": "^12.5.4",
    "mysql2": "^3.22.3",
    "p-queue": "^9.3.0",
    "p-timeout": "^7.0.1",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@ava/typescript": "^7.0.0",
    "@biomejs/biome": "^2.4.15",
    "@tsconfig/node22": "^22.0.5",
    "@types/convict": "^6.1.6",
    "@types/cron": "^2.4.3",
    "@types/debug": "^4.1.13",
    "@types/deep-equal": "^1.0.4",
    "@types/mime-types": "^3.0.1",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.19.19",
    "@yarnpkg/sdks": "^3.2.3",
    "ava": "8.0.1",
    "ava-nock": "^2.1.0",
    "browserslist": "^4.28.2",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "tslib": "^2.8.1",
    "type-fest": "^5.6.0",
    "typescript": "6.0.3",
    "update-browserslist-db": "^1.2.3"
  },
  "resolutions": {
    "@oada/lib-prom": "^4.0.1",
    "cross-spawn": "^7.0.5",
    "jsonpath-plus": "^10.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "packageManager": "yarn@4.15.0",
  "volta": {
    "node": "22.9.0"
  }
}
